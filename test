# 測試單一標題
def test_single_title(model, tokenizer, title, device):
    model.eval()
    # 分詞
    tokens = tokenizer(title, padding=True, truncation=True, max_length=128, return_tensors="pt")
    input_ids = tokens['input_ids'].to(device)
    attention_mask = tokens['attention_mask'].to(device)
    
    # 前向傳播
    with torch.no_grad():
        output = model(input_ids, attention_mask)
    
    # 輸出結果
    predicted_value = output.squeeze().item()
    print(f"Title: {title}")
    print(f"Predicted Normalized PV: {predicted_value:.4f}")

# 測試範例
